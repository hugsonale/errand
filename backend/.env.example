# ─────────────────────────────────────────
# ERRAND MARKETPLACE — ENVIRONMENT CONFIG
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ─────────────────────────────────────────

# App
APP_NAME="Errand Marketplace API"
APP_ENV=development            # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql+asyncpg://errand_user:errand_pass@localhost:5432/errand_marketplace
DATABASE_URL_SYNC=postgresql://errand_user:errand_pass@localhost:5432/errand_marketplace

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-west-1
S3_BUCKET_NAME=errand-marketplace-media
S3_PRESIGNED_URL_EXPIRE=3600

# SMS / OTP — Termii (Nigerian SMS provider)
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=ErrandApp
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

# Paystack (Phase 3 — leave blank for now)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Firebase FCM (Phase 3 — leave blank for now)
FIREBASE_CREDENTIALS_PATH=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Admin
FIRST_ADMIN_EMAIL=admin@errandmarketplace.com
FIRST_ADMIN_PASSWORD=ChangeThisPassword123!
